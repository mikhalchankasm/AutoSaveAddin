<Window x:Class="AutoSaveAddin.AutoSaveConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:loc="clr-namespace:AutoSaveAddin.Localization"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="220"
        Width="480"
        Name="uc"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F7FAF8"
        Loaded="Window_OnLoaded"
        FocusManager.FocusedElement="{Binding ElementName=YesButton}">
    <Border Margin="12" Padding="16" Background="#FFFFFF" BorderBrush="#D7E2DE" BorderThickness="1" CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="46" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="14" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0" Grid.ColumnSpan="3" VerticalAlignment="Center">
                <TextBlock Text="{Binding Message}" FontSize="15" FontWeight="SemiBold" Foreground="#21312D" TextWrapping="Wrap" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding Details}" Margin="0,8,0,0" Foreground="#667871" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Stretch">
                <Button Name="YesButton" Height="34" Width="185" Command="{Binding YesCommand, ElementName=uc}" Background="#DFF2E6" BorderBrush="#8CC8A0" Foreground="#205B34" FontWeight="SemiBold" ToolTipService.ShowDuration="30000">
                    <Button.ToolTip>
                        <ToolTip>
                            <TextBlock FontSize="14" MaxWidth="360" TextWrapping="Wrap" Text="{x:Static loc:UiText.ConfirmSaveHelp}" />
                        </ToolTip>
                    </Button.ToolTip>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding YesText}" />
                        <TextBlock Text="{Binding Time, StringFormat=  ({0})}" />
                    </StackPanel>
                </Button>
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Stretch">
                <Button Name="NoButton" Height="34" Width="185" Content="{Binding NoText}" Command="{Binding NoCommand, ElementName=uc}" Background="#F7E1E1" BorderBrush="#D69A9A" Foreground="#7A2D2D" FontWeight="SemiBold" ToolTipService.ShowDuration="30000">
                    <Button.ToolTip>
                        <ToolTip>
                            <TextBlock FontSize="14" MaxWidth="360" TextWrapping="Wrap" Text="{x:Static loc:UiText.CancelSaveHelp}" />
                        </ToolTip>
                    </Button.ToolTip>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
