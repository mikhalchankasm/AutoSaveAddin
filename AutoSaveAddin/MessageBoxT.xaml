<Window x:Class="AutoSaveAddin.MessageBoxT"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:AutoSaveAddin"
        mc:Ignorable="d"
        Title="{Binding Title}" Height="150" Width="300" Name="uc" Loaded="MessageBoxT_OnLoaded"
        FocusManager.FocusedElement="{Binding ElementName=YesButton}">
    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>
                
        <TextBlock Grid.ColumnSpan="2" Text="{Binding Message}" VerticalAlignment="Center" Margin="5"/>
                
        <Button Name="YesButton" Grid.Row="1" Grid.Column="0" Width="50" VerticalAlignment="Center" HorizontalAlignment="Center" Command="{Binding YesCommand, ElementName=uc}">
            <TextBlock Text="{Binding Time, StringFormat=Да({0})}"/>
        </Button>
        <Button Name="NoButton" Grid.Row="1" Grid.Column="1" Width="50" Content="Нет" VerticalAlignment="Center" HorizontalAlignment="Center" Command="{Binding NoCommand, ElementName=uc}"/>
    </Grid>
</Window>