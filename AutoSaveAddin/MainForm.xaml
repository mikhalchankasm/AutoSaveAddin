<Window x:Class="AutoSaveAddin.MainForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:converters="clr-namespace:AutoSaveAddin.Converters"
        xmlns:loc="clr-namespace:AutoSaveAddin.Localization"
        mc:Ignorable="d"
        Height="470"
        Width="760"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7F6"
        Closing="Window_Closing"
        Loaded="Window_Loaded"
        Title="{x:Static loc:UiText.SettingsWindowTitle}">
    <Window.Resources>
        <converters:TimeSpanToMinConverter x:Key="TimeSpanToMinConverter" />
        <converters:TimeSpanToSecConverter x:Key="TimeSpanToSecConverter" />

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#263330" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SmallButton" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#E8EFED" />
            <Setter Property="BorderBrush" Value="#B8C7C2" />
            <Setter Property="Foreground" Value="#21312D" />
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#F2F5F4" />
            <Setter Property="BorderBrush" Value="#C9D5D1" />
            <Setter Property="Foreground" Value="#31423D" />
        </Style>

        <Style x:Key="HelpIcon" TargetType="TextBlock">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#49645C" />
            <Setter Property="Background" Value="#EDF3F1" />
            <Setter Property="ToolTipService.ShowDuration" Value="30000" />
        </Style>

        <Style x:Key="ValueBox" TargetType="TextBox">
            <Setter Property="Width" Value="58" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#B8C7C2" />
        </Style>
    </Window.Resources>

    <Border Margin="14" Padding="16" Background="#FFFFFF" BorderBrush="#D6E0DD" BorderThickness="1" CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="36" />
                <RowDefinition Height="36" />
                <RowDefinition Height="36" />
                <RowDefinition Height="36" />
                <RowDefinition Height="42" />
                <RowDefinition Height="42" />
                <RowDefinition Height="12" />
                <RowDefinition Height="0" />
                <RowDefinition Height="58" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="295" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0">
                <TextBlock Text="{x:Static loc:UiText.SettingsHeader}" FontSize="18" FontWeight="SemiBold" Foreground="#1F2F2B" />
                <TextBlock Text="{x:Static loc:UiText.SettingsSubtitle}" Margin="0,4,12,0" Foreground="#60736D" TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <Button Style="{StaticResource SecondaryButton}" Content="&#x2197;" ToolTip="{x:Static loc:UiText.OpenJsonButtonTooltip}" Command="{Binding OpenSettingsFileCommand}" />
                <TextBlock Style="{StaticResource HelpIcon}" Text="?">
                    <TextBlock.ToolTip>
                        <ToolTip>
                            <TextBlock FontSize="14" MaxWidth="340" TextWrapping="Wrap" Text="{x:Static loc:UiText.OpenJsonHelp}" />
                        </ToolTip>
                    </TextBlock.ToolTip>
                </TextBlock>
                <Button Style="{StaticResource SecondaryButton}" Content="&#x2713;" ToolTip="{x:Static loc:UiText.CheckJsonButtonTooltip}" Command="{Binding NormalizeSettingsFileCommand}" />
                <TextBlock Style="{StaticResource HelpIcon}" Text="?">
                    <TextBlock.ToolTip>
                        <ToolTip>
                            <TextBlock FontSize="14" MaxWidth="340" TextWrapping="Wrap" Text="{x:Static loc:UiText.CheckJsonHelp}" />
                        </ToolTip>
                    </TextBlock.ToolTip>
                </TextBlock>
            </StackPanel>

            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelText}" Text="{x:Static loc:UiText.EnabledLabel}" />
            <CheckBox Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" IsChecked="{Binding Settings.Enabled}" />

            <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource LabelText}" Text="{x:Static loc:UiText.AskBeforeSaveLabel}" />
            <CheckBox Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" IsChecked="{Binding Settings.IsNeedRequest}" />

            <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource LabelText}" Text="{x:Static loc:UiText.StrictConfirmationLabel}" />
            <CheckBox Grid.Row="4" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" IsChecked="{Binding Settings.RequireConfirmationToSave}" />

            <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource LabelText}" Text="{x:Static loc:UiText.UnclaimAfterSaveLabel}" />
            <CheckBox Grid.Row="5" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" IsChecked="{Binding Settings.UnclaimAfterSave}" />

            <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource LabelText}" Text="{x:Static loc:UiText.SaveIntervalLabel}" />
            <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource SmallButton}" Content="-" Command="{Binding DecreaseDelayCommand}" />
                <TextBlock Style="{StaticResource HelpIcon}" Text="?">
                    <TextBlock.ToolTip>
                        <ToolTip>
                            <TextBlock FontSize="14" MaxWidth="320" TextWrapping="Wrap" Text="{x:Static loc:UiText.DecreaseIntervalHelp}" />
                        </ToolTip>
                    </TextBlock.ToolTip>
                </TextBlock>
                <TextBox Style="{StaticResource ValueBox}" Text="{Binding Settings.Delay, Converter={StaticResource TimeSpanToMinConverter}, UpdateSourceTrigger=PropertyChanged}" />
                <Button Style="{StaticResource SmallButton}" Content="+" Command="{Binding IncreaseDelayCommand}" />
                <TextBlock Style="{StaticResource HelpIcon}" Text="?">
                    <TextBlock.ToolTip>
                        <ToolTip>
                            <TextBlock FontSize="14" MaxWidth="320" TextWrapping="Wrap" Text="{x:Static loc:UiText.IncreaseIntervalHelp}" />
                        </ToolTip>
                    </TextBlock.ToolTip>
                </TextBlock>
            </StackPanel>

            <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource LabelText}" Text="{x:Static loc:UiText.ResponseTimeoutLabel}" />
            <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource SmallButton}" Content="-" Command="{Binding DecreaseCloseDelayCommand}" />
                <TextBlock Style="{StaticResource HelpIcon}" Text="?">
                    <TextBlock.ToolTip>
                        <ToolTip>
                            <TextBlock FontSize="14" MaxWidth="320" TextWrapping="Wrap" Text="{x:Static loc:UiText.DecreaseTimeoutHelp}" />
                        </ToolTip>
                    </TextBlock.ToolTip>
                </TextBlock>
                <TextBox Style="{StaticResource ValueBox}" Text="{Binding Settings.CloseDelay, Converter={StaticResource TimeSpanToSecConverter}, UpdateSourceTrigger=PropertyChanged}" />
                <Button Style="{StaticResource SmallButton}" Content="+" Command="{Binding IncreaseCloseDelayCommand}" />
                <TextBlock Style="{StaticResource HelpIcon}" Text="?">
                    <TextBlock.ToolTip>
                        <ToolTip>
                            <TextBlock FontSize="14" MaxWidth="320" TextWrapping="Wrap" Text="{x:Static loc:UiText.IncreaseTimeoutHelp}" />
                        </ToolTip>
                    </TextBlock.ToolTip>
                </TextBlock>
            </StackPanel>

            <TextBlock Grid.Row="10" Grid.Column="0" Text="{Binding StatusText}" Foreground="#2D7D46" VerticalAlignment="Center" FontWeight="SemiBold" />
            <StackPanel Grid.Row="10" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,8,4,8">
                <Button Content="{x:Static loc:UiText.SaveSettingsButton}" Width="205" Height="34" Command="{Binding SaveCommand}" Background="#DDEFE4" BorderBrush="#7CB58E" Foreground="#1F5A33" FontWeight="SemiBold" />
                <TextBlock Style="{StaticResource HelpIcon}" Text="?">
                    <TextBlock.ToolTip>
                        <ToolTip>
                            <TextBlock FontSize="14" MaxWidth="360" TextWrapping="Wrap" Text="{x:Static loc:UiText.SaveSettingsHelp}" />
                        </ToolTip>
                    </TextBlock.ToolTip>
                </TextBlock>
            </StackPanel>
        </Grid>
    </Border>
</Window>
