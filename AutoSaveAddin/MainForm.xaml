<Window x:Class="AutoSaveAddin.MainForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:converters="clr-namespace:AutoSaveAddin.Converters"
        mc:Ignorable="d"
        Height="380"
        Width="540"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7F6"
        Closing="Window_Closing"
        Loaded="Window_Loaded"
        Title="&#x041d;&#x0430;&#x0441;&#x0442;&#x0440;&#x043e;&#x0439;&#x043a;&#x0430; &#x0430;&#x0432;&#x0442;&#x043e;&#x0441;&#x043e;&#x0445;&#x0440;&#x0430;&#x043d;&#x0435;&#x043d;&#x0438;&#x044f;">
    <Window.Resources>
        <converters:TimeSpanToMinConverter x:Key="TimeSpanToMinConverter" />
        <converters:TimeSpanToSecConverter x:Key="TimeSpanToSecConverter" />

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#263330" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SmallButton" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#E8EFED" />
            <Setter Property="BorderBrush" Value="#B8C7C2" />
            <Setter Property="Foreground" Value="#21312D" />
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#F2F5F4" />
            <Setter Property="BorderBrush" Value="#C9D5D1" />
            <Setter Property="Foreground" Value="#31423D" />
        </Style>

        <Style x:Key="ValueBox" TargetType="TextBox">
            <Setter Property="Width" Value="58" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#B8C7C2" />
        </Style>
    </Window.Resources>

    <Border Margin="14" Padding="16" Background="#FFFFFF" BorderBrush="#D6E0DD" BorderThickness="1" CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="36" />
                <RowDefinition Height="36" />
                <RowDefinition Height="36" />
                <RowDefinition Height="42" />
                <RowDefinition Height="42" />
                <RowDefinition Height="12" />
                <RowDefinition Height="0" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="165" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0">
                <TextBlock Text="&#x0410;&#x0432;&#x0442;&#x043e;&#x0441;&#x043e;&#x0445;&#x0440;&#x0430;&#x043d;&#x0435;&#x043d;&#x0438;&#x0435;" FontSize="18" FontWeight="SemiBold" Foreground="#1F2F2B" />
                <TextBlock Text="&#x0418;&#x0437;&#x043c;&#x0435;&#x043d;&#x0435;&#x043d;&#x0438;&#x044f; &#x0432;&#x0441;&#x0442;&#x0443;&#x043f;&#x044f;&#x0442; &#x0432; &#x0441;&#x0438;&#x043b;&#x0443; &#x0442;&#x043e;&#x043b;&#x044c;&#x043a;&#x043e; &#x043f;&#x043e;&#x0441;&#x043b;&#x0435; &#x043d;&#x0430;&#x0436;&#x0430;&#x0442;&#x0438;&#x044f; &#x00ab;&#x0421;&#x043e;&#x0445;&#x0440;&#x0430;&#x043d;&#x0438;&#x0442;&#x044c;&#x00bb;" Margin="0,4,0,0" Foreground="#60736D" />
            </StackPanel>

            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <Button Style="{StaticResource SecondaryButton}" Content="&#x2197;" ToolTip="&#x041e;&#x0442;&#x043a;&#x0440;&#x044b;&#x0442;&#x044c; JSON" Command="{Binding OpenSettingsFileCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Content="&#x2713;" ToolTip="&#x041f;&#x0440;&#x043e;&#x0432;&#x0435;&#x0440;&#x0438;&#x0442;&#x044c; JSON" Command="{Binding NormalizeSettingsFileCommand}" />
            </StackPanel>

            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelText}" Text="&#x0424;&#x0443;&#x043d;&#x043a;&#x0446;&#x0438;&#x044f; &#x0430;&#x0432;&#x0442;&#x043e;&#x0441;&#x043e;&#x0445;&#x0440;&#x0430;&#x043d;&#x0435;&#x043d;&#x0438;&#x044f;" />
            <CheckBox Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" IsChecked="{Binding Settings.Enabled}" />

            <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource LabelText}" Text="&#x0417;&#x0430;&#x043f;&#x0440;&#x043e;&#x0441; &#x043f;&#x0435;&#x0440;&#x0435;&#x0434; &#x0441;&#x043e;&#x0445;&#x0440;&#x0430;&#x043d;&#x0435;&#x043d;&#x0438;&#x0435;&#x043c;" />
            <CheckBox Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" IsChecked="{Binding Settings.IsNeedRequest}" />

            <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource LabelText}" Text="&#x0412;&#x044b;&#x043f;&#x043e;&#x043b;&#x043d;&#x0438;&#x0442;&#x044c; unclaim all &#x043f;&#x043e;&#x0441;&#x043b;&#x0435; &#x0441;&#x043e;&#x0445;&#x0440;&#x0430;&#x043d;&#x0435;&#x043d;&#x0438;&#x044f;" />
            <CheckBox Grid.Row="4" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" IsChecked="{Binding Settings.UnclaimAfterSave}" />

            <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource LabelText}" Text="&#x0418;&#x043d;&#x0442;&#x0435;&#x0440;&#x0432;&#x0430;&#x043b; &#x043c;&#x0435;&#x0436;&#x0434;&#x0443; &#x0441;&#x043e;&#x0445;&#x0440;&#x0430;&#x043d;&#x0435;&#x043d;&#x0438;&#x044f;&#x043c;&#x0438;, &#x043c;&#x0438;&#x043d;" />
            <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource SmallButton}" Content="-" Command="{Binding DecreaseDelayCommand}" />
                <TextBox Style="{StaticResource ValueBox}" Text="{Binding Settings.Delay, Converter={StaticResource TimeSpanToMinConverter}, UpdateSourceTrigger=PropertyChanged}" />
                <Button Style="{StaticResource SmallButton}" Content="+" Command="{Binding IncreaseDelayCommand}" />
            </StackPanel>

            <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource LabelText}" Text="&#x041e;&#x0436;&#x0438;&#x0434;&#x0430;&#x043d;&#x0438;&#x0435; &#x043e;&#x0442;&#x0432;&#x0435;&#x0442;&#x0430; &#x043f;&#x0440;&#x0438; &#x0437;&#x0430;&#x043f;&#x0440;&#x043e;&#x0441;&#x0435;, &#x0441;&#x0435;&#x043a;" />
            <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource SmallButton}" Content="-" Command="{Binding DecreaseCloseDelayCommand}" />
                <TextBox Style="{StaticResource ValueBox}" Text="{Binding Settings.CloseDelay, Converter={StaticResource TimeSpanToSecConverter}, UpdateSourceTrigger=PropertyChanged}" />
                <Button Style="{StaticResource SmallButton}" Content="+" Command="{Binding IncreaseCloseDelayCommand}" />
            </StackPanel>

            <TextBlock Grid.Row="9" Grid.Column="0" Text="{Binding StatusText}" Foreground="#2D7D46" VerticalAlignment="Center" FontWeight="SemiBold" />
            <Button Grid.Row="9" Grid.Column="1" Content="&#x0421;&#x043e;&#x0445;&#x0440;&#x0430;&#x043d;&#x0438;&#x0442;&#x044c; &#x043d;&#x0430;&#x0441;&#x0442;&#x0440;&#x043e;&#x0439;&#x043a;&#x0438;" Width="150" Height="30" HorizontalAlignment="Right" Command="{Binding SaveCommand}" Background="#DDEFE4" BorderBrush="#7CB58E" Foreground="#1F5A33" FontWeight="SemiBold" />
        </Grid>
    </Border>
</Window>
