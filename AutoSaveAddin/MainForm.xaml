<Window x:Class="AutoSaveAddin.MainForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:converters="clr-namespace:AutoSaveAddin.Converters"
        xmlns:loc="clr-namespace:AutoSaveAddin.Localization"
        mc:Ignorable="d"
        Height="560"
        Width="840"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6F7"
        Closing="Window_Closing"
        Loaded="Window_Loaded"
        Title="{x:Static loc:UiText.SettingsWindowTitle}">
    <Window.Resources>
        <converters:TimeSpanToMinConverter x:Key="TimeSpanToMinConverter" />
        <converters:TimeSpanToSecConverter x:Key="TimeSpanToSecConverter" />

        <Style x:Key="TitleText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="21" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#161616" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SettingTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Foreground" Value="#161616" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="SettingDescription" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#7B7B76" />
            <Setter Property="Margin" Value="0,3,12,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="SettingRow" TargetType="Border">
            <Setter Property="Padding" Value="0,9" />
            <Setter Property="BorderBrush" Value="#E2E2DF" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D4D4D0" />
            <Setter Property="Foreground" Value="#545451" />
            <Setter Property="ToolTipService.ShowDuration" Value="30000" />
        </Style>

        <Style x:Key="StepperButton" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Foreground" Value="#4B4B47" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D0D0CC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ToolTipService.ShowDuration" Value="30000" />
        </Style>

        <Style x:Key="ValueBox" TargetType="TextBox">
            <Setter Property="Width" Value="58" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D0D0CC" />
        </Style>

        <Style x:Key="SecondaryActionButton" TargetType="Button">
            <Setter Property="Width" Value="112" />
            <Setter Property="Height" Value="40" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Foreground" Value="#5A5A56" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D0D0CC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ToolTipService.ShowDuration" Value="30000" />
        </Style>

        <Style x:Key="PrimaryActionButton" TargetType="Button">
            <Setter Property="Width" Value="130" />
            <Setter Property="Height" Value="40" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Background" Value="#111111" />
            <Setter Property="BorderBrush" Value="#111111" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ToolTipService.ShowDuration" Value="30000" />
        </Style>

        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Width" Value="52" />
            <Setter Property="Height" Value="30" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="ToolTipService.ShowDuration" Value="30000" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="52" Height="30">
                            <Border x:Name="SwitchTrack" Width="52" Height="30" CornerRadius="15" Background="#CFCFCA" />
                            <Ellipse x:Name="SwitchKnob" Width="24" Height="24" Margin="3" HorizontalAlignment="Left" Fill="#FFFFFF" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="#009500" />
                                <Setter TargetName="SwitchKnob" Property="HorizontalAlignment" Value="Right" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="SwitchTrack" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BannerPanel" TargetType="Border">
            <Setter Property="Background" Value="#D9F2D6" />
            <Setter Property="Padding" Value="24,12" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Settings.Enabled}" Value="False">
                    <Setter Property="Background" Value="#ECECEA" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Margin="18" Background="#FFFFFF" BorderBrush="#DDDDDA" BorderThickness="1" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="58" />
                <RowDefinition Height="78" />
                <RowDefinition Height="*" />
                <RowDefinition Height="62" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#x25A0;" FontSize="13" Foreground="#7B7B76" VerticalAlignment="Center" Margin="0,0,16,0" />
                    <TextBlock Style="{StaticResource TitleText}" Text="{x:Static loc:UiText.SettingsHeader}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource IconButton}" Content="&#x2197;" Command="{Binding OpenSettingsFileCommand}">
                        <Button.ToolTip>
                            <ToolTip>
                                <TextBlock FontSize="14" MaxWidth="340" TextWrapping="Wrap" Text="{x:Static loc:UiText.OpenJsonHelp}" />
                            </ToolTip>
                        </Button.ToolTip>
                    </Button>
                    <Button Style="{StaticResource IconButton}" Content="&#x2713;" Command="{Binding NormalizeSettingsFileCommand}">
                        <Button.ToolTip>
                            <ToolTip>
                                <TextBlock FontSize="14" MaxWidth="340" TextWrapping="Wrap" Text="{x:Static loc:UiText.CheckJsonHelp}" />
                            </ToolTip>
                        </Button.ToolTip>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" Style="{StaticResource BannerPanel}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding BannerTitle}" FontSize="18" FontWeight="SemiBold" Foreground="#006B00" />
                        <TextBlock Text="{Binding BannerDetail}" Margin="0,4,16,0" FontSize="15" Foreground="#006B00" TextWrapping="Wrap" />
                    </StackPanel>
                    <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding Settings.Enabled}" ToolTip="{x:Static loc:UiText.EnabledLabel}" />
                </Grid>
            </Border>

            <Border Grid.Row="2" Padding="24,10,24,8">
                <StackPanel>
                    <Border Style="{StaticResource SettingRow}">
                        <Grid ToolTip="{x:Static loc:UiText.SaveIntervalDescription}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource SettingTitle}" Text="{x:Static loc:UiText.SaveIntervalLabel}" />
                                <TextBlock Style="{StaticResource SettingDescription}" Text="{x:Static loc:UiText.SaveIntervalDescription}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Style="{StaticResource StepperButton}" Content="-" Command="{Binding DecreaseDelayCommand}" ToolTip="{x:Static loc:UiText.DecreaseIntervalHelp}" />
                                <TextBox Style="{StaticResource ValueBox}" Text="{Binding Settings.Delay, Converter={StaticResource TimeSpanToMinConverter}, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Style="{StaticResource StepperButton}" Content="+" Command="{Binding IncreaseDelayCommand}" ToolTip="{x:Static loc:UiText.IncreaseIntervalHelp}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingRow}">
                        <StackPanel>
                            <Grid ToolTip="{x:Static loc:UiText.AskBeforeSaveDescription}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource SettingTitle}" Text="{x:Static loc:UiText.AskBeforeSaveLabel}" />
                                    <TextBlock Style="{StaticResource SettingDescription}" Text="{x:Static loc:UiText.AskBeforeSaveDescription}" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding Settings.IsNeedRequest}" ToolTip="{x:Static loc:UiText.AskBeforeSaveLabel}" />
                            </Grid>

                            <Border Margin="24,8,0,0" Padding="18,0,0,0" BorderBrush="#D8D8D4" BorderThickness="2,0,0,0">
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource SettingTitle}" Text="{x:Static loc:UiText.ResponseTimeoutLabel}" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Style="{StaticResource StepperButton}" Content="-" Command="{Binding DecreaseCloseDelayCommand}" ToolTip="{x:Static loc:UiText.DecreaseTimeoutHelp}" />
                                            <TextBox Style="{StaticResource ValueBox}" Text="{Binding Settings.CloseDelay, Converter={StaticResource TimeSpanToSecConverter}, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button Style="{StaticResource StepperButton}" Content="+" Command="{Binding IncreaseCloseDelayCommand}" ToolTip="{x:Static loc:UiText.IncreaseTimeoutHelp}" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid ToolTip="{x:Static loc:UiText.StrictConfirmationDescription}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Style="{StaticResource SettingTitle}" Text="{x:Static loc:UiText.StrictConfirmationLabel}" />
                                            <TextBlock Style="{StaticResource SettingDescription}" Text="{x:Static loc:UiText.StrictConfirmationDescription}" />
                                        </StackPanel>
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding Settings.RequireConfirmationToSave}" ToolTip="{x:Static loc:UiText.StrictConfirmationLabel}" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Padding="0,9">
                        <Grid ToolTip="{x:Static loc:UiText.UnclaimAfterSaveDescription}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource SettingTitle}" Text="{x:Static loc:UiText.UnclaimAfterSaveLabel}" />
                                <TextBlock Style="{StaticResource SettingDescription}" Text="{x:Static loc:UiText.UnclaimAfterSaveDescription}" />
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding Settings.UnclaimAfterSave}" ToolTip="{x:Static loc:UiText.UnclaimAfterSaveLabel}" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="3" BorderBrush="#E2E2DF" BorderThickness="0,1,0,0" Padding="24,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding StatusText}" Foreground="#7B7B76" FontSize="15" VerticalAlignment="Center" />

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource SecondaryActionButton}" Content="{x:Static loc:UiText.ResetSettingsButton}" Command="{Binding ResetCommand}">
                            <Button.ToolTip>
                                <ToolTip>
                                    <TextBlock FontSize="14" MaxWidth="360" TextWrapping="Wrap" Text="{x:Static loc:UiText.ResetSettingsHelp}" />
                                </ToolTip>
                            </Button.ToolTip>
                        </Button>
                        <Button Style="{StaticResource PrimaryActionButton}" Content="{x:Static loc:UiText.ApplySettingsButton}" Command="{Binding SaveCommand}" Margin="14,0,0,0">
                            <Button.ToolTip>
                                <ToolTip>
                                    <TextBlock FontSize="14" MaxWidth="360" TextWrapping="Wrap" Text="{x:Static loc:UiText.SaveSettingsHelp}" />
                                </ToolTip>
                            </Button.ToolTip>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
